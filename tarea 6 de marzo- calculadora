print("Implementar una calculadora mediante la creación de una clase 'Calculadora'")

class Calculadora:

    def suma(self, a, b):
        print("Suma:", a + b)

    def resta(self, a, b):
        print("Resta:", a - b)

    def multiplicacion(self, a, b):
        print("Multiplicación:", a * b)

    def division_entera(self, a, b):
        print("División entera:", a // b)

    def modulo(self, a, b):
        print("Módulo:", a % b)

    def potencia(self, a, b):
        print("Potencia:", a ** b)

    def raiz_cuadrada(self, a):
        print("Raíz cuadrada:", a ** 0.5)


# Crear objeto
calc = Calculadora()

# Pedir números al usuario
a = int(input("Ingrese el valor de a: "))
b = int(input("Ingrese el valor de b: "))

calc.suma(a, b)
calc.resta(a, b)
calc.multiplicacion(a, b)
calc.division_entera(a, b)
calc.modulo(a, b)
calc.potencia(a, b)
calc.raiz_cuadrada(a)

